PORT=3000
CORS_ORIGIN=http://localhost:5173
# Base URL embedded in QR payloads (verification page). Defaults to CORS_ORIGIN/v.
VERIFY_BASE_URL=http://localhost:5173/v

# SEC-02 — comma-separated IP allowlist for the code-generation endpoint.
# Leave blank for local dev; SET FOR PRODUCTION.
ADMIN_GEN_IP_ALLOWLIST=

# File storage now lives entirely on the frontend (Cloudinary direct upload).
# See frontend/.env.example for VITE_CLOUDINARY_* settings.
JWT_SECRET=change-me-in-prod-please-use-a-long-random-string
JWT_EXPIRES_IN=1d
ADMIN_API_TOKEN=change-me-admin-shared-secret

# Prisma
DATABASE_URL="file:./aval.sqlite"

# Resend
RESEND_API_KEY=
RESEND_FROM="Aval <noreply@aval.cm>"
